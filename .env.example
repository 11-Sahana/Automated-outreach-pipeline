# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ── Ocean.io ───────────────────────────────────────────
OCEAN_API_KEY=your_ocean_api_key_here
OCEAN_BASE_URL=https://api.ocean.io/v1
OCEAN_LOOKALIKE_LIMIT=10

# ── Prospeo ────────────────────────────────────────────
PROSPEO_API_KEY=your_prospeo_api_key_here
PROSPEO_BASE_URL=https://api.prospeo.io/v1

# ── Eazyreach ──────────────────────────────────────────
EAZYREACH_API_KEY=your_eazyreach_api_key_here
EAZYREACH_BASE_URL=https://api.eazyreach.io/v1

# ── Brevo ──────────────────────────────────────────────
BREVO_API_KEY=your_brevo_api_key_here
BREVO_BASE_URL=https://api.brevo.com/v3
SENDER_EMAIL=you@yourdomain.com
SENDER_NAME=Your Name

# ── Behaviour ──────────────────────────────────────────
MAX_RETRIES=3
RETRY_BACKOFF_FACTOR=2.0
RATE_LIMIT_DELAY=1.0     # seconds between calls to the same service

# ── Logging ────────────────────────────────────────────
LOG_LEVEL=INFO
# LOG_FILE=outreach.log   # uncomment to also write to a file
